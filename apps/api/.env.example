# Server
PORT=4000
NODE_ENV=development
API_BASE_URL=http://localhost:4000
WEB_APP_URL=http://localhost:5173

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Default organization (single-tenant MVP)
DEFAULT_ORGANIZATION_ID=00000000-0000-0000-0000-000000000001

# Claude
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL_QUALIFICATION=claude-sonnet-4-5-20250929
CLAUDE_MODEL_RESEARCH=claude-sonnet-4-5-20250929
CLAUDE_MODEL_OUTREACH=claude-sonnet-4-5-20250929
CLAUDE_MODEL_COPILOT=claude-sonnet-4-5-20250929

# Embeddings (used for company/existing-client similarity vectors)
EMBEDDINGS_PROVIDER=voyage
VOYAGE_API_KEY=your-voyage-api-key

# Apollo
APOLLO_API_KEY=your-apollo-api-key
APOLLO_BASE_URL=https://api.apollo.io/v1

# n8n
N8N_BASE_URL=https://your-instance.app.n8n.cloud
N8N_API_KEY=your-n8n-api-key
N8N_WEBHOOK_SECRET=change-me-shared-hmac-secret

# Internal service-to-service auth (job worker, cron triggers)
INTERNAL_SERVICE_KEY=change-me-internal-key

# Mail — OTP codes are generated by Supabase Admin (no Supabase email sent).
# We deliver the numeric code ourselves:
#
# 1) Production on Render free: set RESEND_API_KEY (https://resend.com — free
#    tier, HTTPS, not blocked). Until you verify a domain, use:
#      RESEND_FROM="Leadify <onboarding@resend.dev>"
#    and note: with the free onboarding sender you can only email the address
#    you signed up to Resend with (fine for demos to your own inbox).
# 2) Local: SMTP_* with a Gmail App Password works on your machine.
#
# Do not rely on SMTP_* alone on Render free — ports 25/465/587 are blocked.
RESEND_API_KEY=
RESEND_FROM="Leadify <onboarding@resend.dev>"

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yhsai35@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM="Leadify <yhsai35@gmail.com>"
